<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/ll_payments_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_auth_header">

        <ImageView
            android:id="@+id/btn_category_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tv_payments_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Платежи и услуги"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Categories grid (shown first) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_categories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_bg"
        android:clipToPadding="false"
        android:padding="10dp"
        android:visibility="visible" />

    <!-- Services list (shown after category tap) -->
    <LinearLayout
        android:id="@+id/ll_services"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_payments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/app_bg"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="24dp" />

    </LinearLayout>

</LinearLayout>
