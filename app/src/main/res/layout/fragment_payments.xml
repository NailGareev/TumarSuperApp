<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F6">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header_payments"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <FrameLayout
            android:id="@+id/btn_back_payments"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_topup_back_btn"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="&#8592;"
                android:textSize="18sp"
                android:textColor="#212121" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_payments_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Платежи и услуги"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111" />
    </LinearLayout>

    <!-- Header divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#E6E6E6" />

    <!-- CATEGORIES VIEW -->
    <ScrollView
        android:id="@+id/layout_categories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_pay_search"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#128269;"
                        android:textSize="16sp"
                        android:textColor="#888888"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Поиск платежа или услуги"
                        android:textSize="14sp"
                        android:textColor="#BBBBBB" />
                </LinearLayout>
            </LinearLayout>

            <!-- Search bar bottom border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#E6E6E6" />

            <!-- Favorites section -->
            <LinearLayout
                android:id="@+id/section_favorites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ИЗБРАННОЕ"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textColor="#777777" />

                    <TextView
                        android:id="@+id/tv_edit_favorites"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Изменить &#8594;"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#6200EE"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_favorites_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />
            </LinearLayout>

            <!-- Favorites section bottom border -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#E6E6E6" />

            <!-- Categories grid section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="10dp"
                android:paddingBottom="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ВСЕ КАТЕГОРИИ"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:textColor="#777777"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_categories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- SERVICES VIEW -->
    <LinearLayout
        android:id="@+id/layout_services"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Search bar for services -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_pay_search"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128269;"
                    android:textSize="16sp"
                    android:textColor="#888888"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tv_service_search_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Поиск..."
                    android:textSize="14sp"
                    android:textColor="#BBBBBB" />
            </LinearLayout>
        </LinearLayout>

        <!-- Services search bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#E6E6E6" />

        <!-- Country tabs (shown only for Мобильная связь) -->
        <LinearLayout
            android:id="@+id/section_country_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/ll_country_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#E6E6E6" />
        </LinearLayout>

        <!-- Services list wrapped in a card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="14dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_payments"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_pay_service_list"
                android:clipToPadding="true"
                android:clipChildren="true" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
