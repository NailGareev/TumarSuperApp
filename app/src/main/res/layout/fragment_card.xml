<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg"
    tools:context=".CardFragment">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_auth_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Моя карта"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_auth_form">

        <!-- No card state -->
        <LinearLayout
            android:id="@+id/layout_no_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳"
                android:textSize="64sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/no_card_message"
                android:textSize="17sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_create_card"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="@string/create_card_button"
                android:textSize="16sp"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <!-- Card details state -->
        <LinearLayout
            android:id="@+id/layout_card_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="top"
            android:padding="20dp"
            android:visibility="gone">

            <!-- Virtual card visual -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_view_clickable_area"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#6200EE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:background="@drawable/bg_wallet_card"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/text_card_custom_name_main"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#DDFFFFFF"
                        android:textSize="15sp"
                        android:visibility="gone"
                        tools:text="Карта для покупок"
                        tools:visibility="visible" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TUMAR"
                        android:textColor="#AAFFFFFF"
                        android:textSize="12sp"
                        android:letterSpacing="0.15"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_card_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        tools:text="7722 33XX XXXX XXXX"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.05" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_expiry_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/card_expiry_label"
                                android:textColor="#99FFFFFF"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/text_card_expiry"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="12/30"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/text_cvv_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/card_cvv_label"
                                android:textColor="#99FFFFFF"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/text_card_cvv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="•••"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="monospace"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Blocked overlay -->
                    <TextView
                        android:id="@+id/text_card_blocked_overlay_main"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#CC000000"
                        android:gravity="center"
                        android:text="@string/card_blocked_overlay_text"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Security warning -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_badge_red"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️  "
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_security_warning"
                    android:textSize="13sp"
                    android:textColor="@color/expense_color" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</LinearLayout>
