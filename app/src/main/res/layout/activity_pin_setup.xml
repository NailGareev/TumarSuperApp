<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E2E"
    tools:context=".PinSetupActivity">

    <!-- Gradient header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_auth_header">

        <androidx.cardview.widget.CardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="T"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#6200EE" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tumar SuperApp"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- PIN content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <TextView
            android:id="@+id/tv_pin_instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Придумайте ПИН-код"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- PIN dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <View android:id="@+id/pin_dot_1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_pin_dot_empty" />
            <View android:id="@+id/pin_dot_2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_pin_dot_empty" />
            <View android:id="@+id/pin_dot_3"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_pin_dot_empty" />
            <View android:id="@+id/pin_dot_4"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_pin_dot_empty" />
        </LinearLayout>

        <!-- Error text -->
        <TextView
            android:id="@+id/tv_pin_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#FF5252"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="ПИН-коды не совпадают"
            tools:visibility="visible" />

        <!-- Keypad -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/key_1" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="1" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_2" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="2" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_3" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="3" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/key_4" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="4" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_5" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="5" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_6" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="6" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/key_7" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="7" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_8" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="8" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_9" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="9" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                <View android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" />
                <Button android:id="@+id/key_0" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="0" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" />
                <Button android:id="@+id/key_backspace" android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_key" android:text="⌫" android:textColor="#FFFFFF" android:textSize="22sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
