<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F5FF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Уведомления"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Tab bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="1dp">

        <!-- Tab: Переводы -->
        <LinearLayout
            android:id="@+id/tab_transfers"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/tab_text_transfers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Переводы"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#6200EE" />

                <TextView
                    android:id="@+id/tab_badge_transfers"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:gravity="center"
                    android:text="0"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_notification_badge"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:id="@+id/tab_indicator_transfers"
                android:layout_width="match_parent"
                android:layout_height="2.5dp"
                android:layout_gravity="bottom"
                android:layout_marginTop="6dp"
                android:background="#6200EE" />
        </LinearLayout>

        <!-- Tab: Tumar Market -->
        <LinearLayout
            android:id="@+id/tab_market"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center">

                <TextView
                    android:id="@+id/tab_text_market"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tumar Market"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#9E9E9E" />

                <TextView
                    android:id="@+id/tab_badge_market"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:gravity="center"
                    android:text="0"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_notification_badge"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:id="@+id/tab_indicator_market"
                android:layout_width="match_parent"
                android:layout_height="2.5dp"
                android:layout_gravity="bottom"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <!-- Tab: Tumar Credit -->
        <LinearLayout
            android:id="@+id/tab_credit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp">

            <TextView
                android:id="@+id/tab_text_credit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tumar Credit"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:layout_gravity="center" />

            <View
                android:id="@+id/tab_indicator_credit"
                android:layout_width="match_parent"
                android:layout_height="2.5dp"
                android:layout_gravity="bottom"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content: Переводы (chat list) -->
    <FrameLayout
        android:id="@+id/content_transfers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_transfer_notifs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:clipToPadding="false"
            android:paddingBottom="12dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_transfers"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/empty_transfers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💸"
                android:textSize="52sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Нет переводов"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Здесь появятся входящие\nи исходящие переводы"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- Content: Market -->
    <FrameLayout
        android:id="@+id/content_market"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_market_notifs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:clipToPadding="false"
            android:paddingBottom="12dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_market"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/empty_market"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍"
                android:textSize="52sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Нет уведомлений"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Здесь появятся статусы\nваших заказов"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
        </LinearLayout>
    </FrameLayout>

    <!-- Content: Credit (empty state) -->
    <FrameLayout
        android:id="@+id/content_credit"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/empty_credit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="36dp">

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:background="@drawable/bg_tag_credit"
                android:layout_marginBottom="18dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳"
                    android:textSize="28sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Нет уведомлений"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Здесь появятся уведомления\nпо кредитным продуктам Tumar"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Узнать о кредитах →"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#6200EE"
                android:background="@drawable/bg_chip_purple"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
