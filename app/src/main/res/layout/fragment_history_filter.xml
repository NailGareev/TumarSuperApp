<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#CCCCCC"
        android:alpha="0.7" />

    <!-- Sheet header: Фильтры + Сбросить + X -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Фильтры"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#111111" />

        <TextView
            android:id="@+id/btn_filter_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="Сбросить"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:background="@drawable/bg_chip_purple"
            android:clickable="true"
            android:focusable="true" />

        <FrameLayout
            android:id="@+id/btn_filter_close"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_topup_back_btn"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textSize="13sp"
                android:textColor="#555555" />
        </FrameLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1px" android:background="#E6E6E6" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Период -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:text="ПЕРИОД"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#777777"
                android:letterSpacing="0.1" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/chip_f_today"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="Сегодня"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_week"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Неделя"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_month"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Месяц"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple_active"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_3months"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="3 месяца"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_custom"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Свой диапазон"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#AAAAAA"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:alpha="0.5"
                        android:clickable="false"
                        android:focusable="false" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Категория -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="КАТЕГОРИЯ"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#777777"
                android:letterSpacing="0.1" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/chip_f_cat_all"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:text="Все"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple_active"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_cat_market"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Market"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_cat_transfer"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Переводы"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_cat_payment"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Платежи"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_f_cat_income"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:text="Доходы"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Тип операции -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="ТИП ОПЕРАЦИИ"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#777777"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="18dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chip_f_type_all"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Все операции"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_chip_purple_active"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_f_type_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:text="Расходы"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_f_type_income"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginStart="8dp"
                    android:text="Доходы"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Сумма -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="СУММА"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#777777"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_history_item_single"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="От"
                        android:textSize="10sp"
                        android:textColor="#777777" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="₸ 0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#BBBBBB" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:text="—"
                    android:textSize="16sp"
                    android:textColor="#BBBBBB" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_history_item_single"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="До"
                        android:textSize="10sp"
                        android:textColor="#777777" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Любая"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#BBBBBB" />
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="16dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Apply button -->
    <TextView
        android:id="@+id/btn_filter_apply"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="Применить фильтры"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/bg_topup_cta_btn"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
