<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg"
    tools:context=".HistoryFragment">

    <!-- Purple header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_auth_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="История операций"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Period filter chips row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:elevation="2dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chip_period_1m"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="1 мес"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_chip_purple_active"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_3m"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="3 мес"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_6m"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="6 мес"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_1y"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="1 год"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Summary CardView -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="0dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Income / Expense row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- Income side -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Поступления"
                        android:textSize="11sp"
                        android:textColor="@color/income_color" />

                    <TextView
                        android:id="@+id/tv_summary_income"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+0 ₸"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/income_color"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Vertical divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="#E0E0E0" />

                <!-- Expense side -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📉 Расходы"
                        android:textSize="11sp"
                        android:textColor="@color/expense_color" />

                    <TextView
                        android:id="@+id/tv_summary_expense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-0 ₸"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/expense_color"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Bottom thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />

            <!-- "Подробнее по категориям" link -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Подробнее по категориям →"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="10dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Transactions list area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_transactions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            tools:listitem="@layout/item_transaction" />

        <ProgressBar
            android:id="@+id/progressBarHistory"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/tv_history_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="56sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="История пуста"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Здесь появятся ваши переводы,\nпополнения и платежи"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
