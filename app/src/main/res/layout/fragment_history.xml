<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F6"
    tools:context=".HistoryFragment">

    <!-- Compact white header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="#FFFFFF">

        <FrameLayout
            android:id="@+id/btn_history_back"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_topup_back_btn"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                android:tint="#212121"
                android:contentDescription="@null" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="История операций"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#111111" />

        <FrameLayout
            android:id="@+id/btn_history_search"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_topup_back_btn"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🔍"
                android:textSize="15sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_history_filter"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_topup_back_btn"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="▽"
                android:textSize="14sp"
                android:textColor="#555555" />
        </FrameLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#E6E6E6" />

    <!-- Period tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chip_period_1w"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="1 нед"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_1m"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="1 мес"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple_active"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_3m"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="3 мес"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_6m"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="6 мес"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chip_period_1y"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="1 год"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_purple"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#E6E6E6" />

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Summary card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="0dp"
                android:background="@drawable/bg_history_item_single"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/card_summary"
                android:padding="14dp">

                <!-- Income / Expense row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ПОСТУПЛЕНИЯ"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tv_summary_income"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ 0 ₸"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/income_color"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="#E6E6E6" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="РАСХОДЫ"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tv_summary_expense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-0 ₸"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/expense_color"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Mini bar chart (weekly spending) -->
                <com.digitalcompany.tumarsuperapp.MiniBarChartView
                    android:id="@+id/mini_bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1px"
                    android:background="#E6E6E6"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Подробнее по категориям →"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Category filter chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="2dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/chip_cat_all"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Все"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_chip_purple_active"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_cat_market"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Market"
                        android:textSize="12sp"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_cat_transfer"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Переводы"
                        android:textSize="12sp"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_cat_payment"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Платежи"
                        android:textSize="12sp"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/chip_cat_income"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:text="Доходы"
                        android:textSize="12sp"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_purple"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Transactions list -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingBottom="16dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_transaction" />

                <ProgressBar
                    android:id="@+id/progressBarHistory"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/tv_history_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp"
                    android:layout_marginTop="40dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="48sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="История пуста"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Здесь появятся ваши переводы,&#10;пополнения и платежи"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </FrameLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
