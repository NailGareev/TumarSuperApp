<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F4F6">

    <!-- Chat header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="14dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:id="@+id/btn_chat_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="←"
            android:textSize="20sp"
            android:textColor="#444444"
            android:background="@drawable/bg_settings_btn"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Avatar -->
        <TextView
            android:id="@+id/tv_chat_header_avatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_icon_circle_purple"
            android:layout_marginEnd="10dp" />

        <!-- Name + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_chat_header_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Имя"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tv_chat_header_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Чат по переводам"
                android:textSize="11sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>
    </LinearLayout>

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp" />

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <EditText
            android:id="@+id/et_chat_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Написать комментарий…"
            android:hintTextColor="#BDBDBD"
            android:textSize="14sp"
            android:textColor="#212121"
            android:background="@drawable/bg_chat_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:maxLines="3"
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionSend" />

        <TextView
            android:id="@+id/btn_chat_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="↑"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_send_btn"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
