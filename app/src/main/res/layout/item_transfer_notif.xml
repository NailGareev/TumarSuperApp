<?xml version="1.0" encoding="utf-8"?>
<!-- Messenger-style chat row for Transfers tab -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar circle with initial letter or photo -->
    <FrameLayout
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tv_avatar_initial"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:text="A"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_icon_circle_purple" />

        <ImageView
            android:id="@+id/iv_avatar_photo"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Фото" />

        <!-- Online indicator -->
        <View
            android:id="@+id/view_online_dot"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_dot_active"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Info column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 1: name + time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_chat_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Имя"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_chat_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="12:00"
                android:textSize="11sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>

        <!-- Row 2: last message + amount + badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/tv_chat_last_msg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Последнее сообщение…"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:singleLine="true"
                android:ellipsize="end" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tv_chat_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-5 000 ₸"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#C62828"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_chat_unread"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:text="1"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_notification_badge"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
