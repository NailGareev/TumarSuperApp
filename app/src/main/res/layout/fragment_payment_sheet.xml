<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_bg"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="12dp"
    android:paddingBottom="28dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="14dp"
        android:background="#BBBBBB"
        android:backgroundTint="@null" />

    <!-- Service header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <FrameLayout
            android:id="@+id/fl_sheet_icon_box"
            android:layout_width="46dp"
            android:layout_height="46dp">

            <TextView
                android:id="@+id/tv_sheet_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="22sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_sheet_service_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/tv_sheet_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="#777777" />
        </LinearLayout>
    </LinearLayout>

    <!-- Account field label -->
    <TextView
        android:id="@+id/tv_sheet_account_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Номер телефона"
        android:textSize="11sp"
        android:textColor="#777777"
        android:layout_marginBottom="5dp" />

    <!-- Account field container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_topup_input_field"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_marginBottom="4dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_sheet_account"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:inputType="text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:imeOptions="actionNext" />

        <ImageView
            android:id="@+id/iv_sheet_check"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/bg_topup_success_inner"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Hidden TextInputLayout for account validation (keeps Java compatibility) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_sheet_account"
        style="@style/AuthInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Amount section label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Сумма пополнения"
        android:textSize="11sp"
        android:textColor="#777777"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="5dp" />

    <!-- Amount display row with underline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|bottom"
        android:paddingBottom="6dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₸"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#777777"
            android:layout_marginEnd="6dp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_sheet_amount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:inputType="numberDecimal"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:hint="0"
            android:textColorHint="#CCCCCC"
            android:imeOptions="actionDone" />
    </LinearLayout>

    <!-- Amount underline -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#6200EE"
        android:layout_marginBottom="12dp" />

    <!-- Hidden TextInputLayout for amount error messages -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_sheet_amount"
        style="@style/AuthInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Amount error text -->
    <TextView
        android:id="@+id/tv_amount_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#D32F2F"
        android:visibility="gone"
        android:layout_marginBottom="4dp" />

    <!-- Quick amount chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/chip_sheet_500"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="500"
            android:textSize="12sp"
            android:textColor="#6200EE"
            android:background="@drawable/bg_pay_chip_country"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/chip_sheet_1000"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="1 000"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pay_chip_country_active"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/chip_sheet_3000"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="3 000"
            android:textSize="12sp"
            android:textColor="#6200EE"
            android:background="@drawable/bg_pay_chip_country"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/chip_sheet_5000"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="5 000"
            android:textSize="12sp"
            android:textColor="#6200EE"
            android:background="@drawable/bg_pay_chip_country"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Info pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_pay_info_pill"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginBottom="14dp">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="#1A8A4A"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Без комиссии · Зачисление мгновенно"
            android:textSize="12sp"
            android:textColor="#1A8A4A" />
    </LinearLayout>

    <!-- Progress indicator -->
    <ProgressBar
        android:id="@+id/progress_sheet"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- CTA Pay button -->
    <LinearLayout
        android:id="@+id/btn_sheet_pay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_topup_cta_btn"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tv_btn_pay_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Оплатить ₸ 0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
