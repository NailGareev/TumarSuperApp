<?xml version="1.0" encoding="utf-8"?>
<!-- Incoming message bubble from other user -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp">

    <!-- Small avatar -->
    <TextView
        android:id="@+id/tv_msg_avatar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:text="A"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_icon_circle_purple"
        android:layout_marginEnd="8dp"
        android:layout_gravity="bottom" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="260dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_other"
        android:paddingStart="13dp"
        android:paddingEnd="13dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp">

        <TextView
            android:id="@+id/tv_msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Текст сообщения"
            android:textSize="14sp"
            android:textColor="#212121" />

        <TextView
            android:id="@+id/tv_msg_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="12:00"
            android:textSize="10sp"
            android:textColor="#BDBDBD" />
    </LinearLayout>
</LinearLayout>
