<?xml version="1.0" encoding="utf-8"?>
<!-- Transfer event card shown inside a chat thread -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp">

    <!-- The card itself, aligned by code (gravity set programmatically) -->
    <LinearLayout
        android:id="@+id/ll_transfer_card_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:maxWidth="290dp"
        android:orientation="vertical"
        android:background="@drawable/bg_transfer_card_mine">

        <!-- Card header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <!-- Icon -->
            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_chip_purple"
                android:layout_marginEnd="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="💸"
                    android:textSize="14sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_card_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Перевод"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Мгновенно · без комиссии"
                    android:textSize="10sp"
                    android:textColor="#B0BEC5" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF" />

        <!-- Amount row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сумма"
                android:textSize="11sp"
                android:textColor="#B0BEC5" />

            <TextView
                android:id="@+id/tv_card_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="- 5 000 ₸"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Description (if any) -->
        <TextView
            android:id="@+id/tv_card_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:text=""
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:visibility="gone" />

        <!-- Time -->
        <TextView
            android:id="@+id/tv_card_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="12:00"
            android:textSize="10sp"
            android:textColor="#80B0BEC5" />
    </LinearLayout>
</LinearLayout>
