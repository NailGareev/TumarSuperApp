<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/app_bg"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar_surface"
        android:elevation="2dp"
        app:elevation="2dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_toolbar_surface"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_secondary"
            app:navigationIconTint="@color/text_primary"
            />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/nav_view"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_nav_surface"
            android:paddingTop="14dp"
            android:paddingBottom="8dp"
            app:elevation="10dp"
            app:itemActiveIndicatorStyle="@null"
            app:itemIconSize="20dp"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemTextAppearanceActive="@style/BottomNavWireframeText"
            app:itemTextAppearanceInactive="@style/BottomNavWireframeText"
            app:itemTextColor="@color/bottom_nav_item_tint"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="bottom"
            android:layout_marginBottom="87dp"
            android:background="#E8E8E8" />

        <FrameLayout
            android:id="@+id/btn_qr_center"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_qr_fab_outer"
            android:clickable="true"
            android:elevation="16dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="7dp"
            android:contentDescription="@string/title_qr">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_qr_fab_inner">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/title_qr"
                    app:srcCompat="@drawable/ic_qr_code_nav" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="74dp"
            android:fontFamily="casual"
            android:text="@string/title_qr"
            android:textColor="@color/colorPrimary"
            android:textSize="14sp" />
    </FrameLayout>

</LinearLayout>
